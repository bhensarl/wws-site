# Copy to .env.local for local dev. In Vercel: Project → Settings → Environment Variables.

# GA4 (optional — default ID is in GoogleAnalytics.tsx)
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-4CCX20DX0Z

# Stripe — Waynewoodstock, LLC publishable key.
# This is the *publishable* key (pk_live_...), which is safe to ship in client-side bundles.
# NEVER put the secret key (sk_live_...) in this repo. Reserved for future Buy-Button / Embedded-Checkout upgrades; current /merch uses anchor links to Stripe-hosted Payment Links and works without this var.
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_xxx
