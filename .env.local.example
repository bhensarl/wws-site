# Copy to .env.local for local dev. In Vercel: Project → Settings → Environment Variables.

# GA4 (optional — default ID is in GoogleAnalytics.tsx)
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-4CCX20DX0Z

# Stripe — Waynewoodstock, LLC.
# Publishable key is safe to ship in client-side bundles. The /api/checkout
# route doesn't read this directly; reserved for future Embedded Checkout.
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_xxx

# Stripe secret key — REQUIRED. Used server-side by /api/checkout to create
# Checkout Sessions. NEVER commit this. NEVER prefix with NEXT_PUBLIC_.
# In Vercel: add to Production + Preview environments only.
STRIPE_SECRET_KEY=sk_live_xxx

# Optional: pin the canonical origin used in Stripe success/cancel redirects.
# Defaults to the request's host header. Set to "https://waynewoodstock.com"
# in production if you want to force the canonical domain.
# NEXT_PUBLIC_SITE_ORIGIN=https://waynewoodstock.com
